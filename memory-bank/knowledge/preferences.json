{
  "version": "1.0.0",
  "lastUpdated": null,
  "coding": {
    "language_preference": ["python", "typescript"],
    "python": {
      "version": "3.11+",
      "type_hints": "always",
      "docstrings": "google_style",
      "formatter": "black",
      "linter": "ruff",
      "test_framework": "pytest"
    },
    "typescript": {
      "strict_mode": true,
      "module_system": "esm",
      "formatter": "prettier",
      "linter": "eslint",
      "test_framework": "vitest"
    }
  },
  "naming": {
    "functions": "snake_case (Python) / camelCase (TS)",
    "classes": "PascalCase",
    "constants": "UPPER_SNAKE_CASE",
    "files": "kebab-case"
  },
  "architecture": {
    "prefer_composition": true,
    "max_function_lines": 50,
    "single_responsibility": true,
    "explicit_over_implicit": true
  },
  "testing": {
    "coverage_target": 80,
    "critical_path_coverage": 100,
    "prefer_fixtures": true,
    "mock_external_only": true
  },
  "review": {
    "focus_areas": [
      "correctness",
      "security",
      "performance",
      "maintainability"
    ],
    "auto_approve_when": [
      "has_existing_tests",
      "changes_under_50_lines",
      "no_public_api_changes"
    ],
    "require_review_when": [
      "modifies_authentication",
      "changes_database_schema",
      "affects_external_api"
    ]
  }
}
